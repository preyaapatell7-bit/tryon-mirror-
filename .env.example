# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GMAIL_USER: Your Gmail address for sending notifications.
GMAIL_USER="your-email@gmail.com"

# GMAIL_PASS: Your Gmail App Password (NOT your regular password).
# See: https://support.google.com/accounts/answer/185833
GMAIL_PASS="your-app-password"

# DESTINATION_EMAIL: Where the user data should be sent.
DESTINATION_EMAIL="preyaapatell7@gmail.com"
